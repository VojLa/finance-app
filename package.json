{
  "name": "finance-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "node scripts/prisma-migrations-frozen.mjs",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:alembic:check": "cd backend/python && uv run python scripts/database_migrate.py check",
    "db:alembic:upgrade": "cd backend/python && uv run python scripts/database_migrate.py upgrade",
    "db:almbic:bootstrap": "cd backend/python && uv run python scripts/database_migrate.py bootstrap",
    "db:prisma:validate": "prisma validate",
    "db:prisma:generate": "prisma generate",
    "db:prisma:studio": "prisma studio",
    "db:prisma:deploy:legacy": "prisma migrate deploy",
    "docker:up": "docker compose up --build",
    "docker:api": "docker compose up api --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "seed": "tsx prisma/seed.ts",
    "prices:backfill": "tsx scripts/backfill-prices.ts",
    "api:compare:portfolio": "tsx scripts/compare-portfolio-api.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^3.0.3",
    "next": "14.2.30",
    "next-auth": "^4.24.11",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "tailwindcss": "^3.4.17",
    "yahoo-finance2": "^2.13.3"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "@types/papaparse": "^2.4.6",
    "@types/react": "19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.30",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prisma": "^6.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
