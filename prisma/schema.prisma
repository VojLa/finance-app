generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String?
  createdAt     DateTime      @default(now())
  accounts      Account[]
  budgets       Budget[]
  importBatches ImportBatch[]
}

model Account {
  id                     String                  @id @default(cuid())
  name                   String
  type                   AccountType
  currency               String
  color                  String?
  userId                 String
  user                   User                    @relation(fields: [userId], references: [id])
  investmentTransactions InvestmentTransaction[]
  transactions           Transaction[]
  holdings               Holding[]
  importBatches          ImportBatch[]
  createdAt              DateTime                @default(now())
}

enum AccountType {
  bank
  broker
  exchange
  cash
  crypto_wallet
}

model Transaction {
  id             String          @id @default(cuid())
  date           DateTime
  amount         Decimal         @db.Decimal(18, 6)
  currency       String
  amountCzk      Decimal?        @db.Decimal(18, 6)
  type           TransactionType
  description    String?
  note           String?
  counterparty   String?
  transactionRef String?
  categoryId     String?
  category       Category?       @relation(fields: [categoryId], references: [id])
  accountId      String
  account        Account         @relation(fields: [accountId], references: [id])
  createdAt      DateTime        @default(now())
}

model Category {
  id           String         @id @default(cuid())
  name         String
  icon         String?
  color        String?
  type         CategoryType
  parentId     String?
  parent       Category?      @relation("Subcategories", fields: [parentId], references: [id])
  children     Category[]     @relation("Subcategories")
  isDefault    Boolean        @default(false)
  userId       String?
  transactions Transaction[]
  budgetItems  BudgetItem[]
  rules        CategoryRule[]
}

enum CategoryType {
  expense
  income
  both
}

model CategoryRule {
  id         String    @id @default(cuid())
  keyword    String
  field      RuleField
  priority   Int       @default(0)
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

enum RuleField {
  description
  counterparty
}

model Budget {
  id        String       @id @default(cuid())
  month     Int
  year      Int
  rollover  Boolean      @default(false)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  items     BudgetItem[]
  createdAt DateTime     @default(now())

  @@unique([month, year, userId])
}

model BudgetItem {
  id             String   @id @default(cuid())
  amount         Decimal  @db.Decimal(18, 6)
  spent          Decimal  @default(0) @db.Decimal(18, 6)
  currency       String   @default("CZK")
  rolloverAmount Decimal? @db.Decimal(18, 6)
  budgetId       String
  budget         Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])
}

enum TransactionType {
  income
  expense
  transfer
}

model InvestmentTransaction {
  id                  String         @id @default(cuid())
  date                DateTime
  type                InvestmentType

  symbol              String?
  isin                String?
  name                String?
  assetType           AssetType?

  quantity            Decimal?       @db.Decimal(28, 10)
  pricePerUnit        Decimal?       @db.Decimal(28, 10)
  priceCurrency       String?

  totalAmount         Decimal?       @db.Decimal(28, 10)
  totalCurrency       String?

  fee                 Decimal?       @db.Decimal(18, 6)
  feeCurrency         String?

  exchangeRate        Decimal?       @db.Decimal(18, 8)

  orderId             String?
  externalId          String?

  realizedPnl         Decimal?       @db.Decimal(28, 10)
  realizedPnlCurrency String?

  accountId           String
  account             Account        @relation(fields: [accountId], references: [id])
  createdAt           DateTime       @default(now())
}

enum InvestmentType {
  buy
  sell
  deposit
  withdrawal
  dividend
  interest
  currency_conversion
  staking_reward
  airdrop
  fee
}

enum AssetType {
  stock
  etf
  crypto
  commodity
  other
}

model Holding {
  id          String    @id @default(cuid())
  symbol      String
  name        String?
  assetType   AssetType
  quantity    Decimal   @db.Decimal(28, 10)
  avgBuyPrice Decimal   @db.Decimal(28, 10)
  currency    String
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id])
  updatedAt   DateTime  @updatedAt

  @@unique([symbol, accountId])
}

model ExchangeRate {
  id           String     @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal    @db.Decimal(18, 8)
  date         DateTime
  source       RateSource

  @@unique([fromCurrency, toCurrency, date])
}

enum RateSource {
  cnb
  ecb
  manual
}

model ImportBatch {
  id        String       @id @default(cuid())
  userId    String
  accountId String
  source    ImportSource
  filename  String
  checksum  String       @unique
  rowCount  Int
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account   Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

enum ImportSource {
  raiffeisenbank
  trading212
  anycoin
  manual
}
