generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User Domain ─────────────────────────────────────────────────────────────

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String?
  passwordHash       String?
  baseCurrency       String             @default("CZK")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  accountMemberships AccountMember[]
  budgets            Budget[]
  budgetAlerts       BudgetAlert[]
  importBatches      ImportBatch[]
  counterparties     Counterparty[]
  netWorthSnapshots  NetWorthSnapshot[]
  sentInvites        AccountInvite[]    @relation("SentAccountInvites")
  acceptedInvites    AccountInvite[]    @relation("AcceptedAccountInvites")
}

// ─── Account Domain ───────────────────────────────────────────────────────────

model Account {
  id                  String               @id @default(cuid())
  name                String
  type                AccountType
  currency            String
  color               String?
  isArchived          Boolean              @default(false)
  archivedAt          DateTime?
  members             AccountMember[]
  investmentEvents    InvestmentEvent[]
  investmentMovements InvestmentMovement[]
  transactions        Transaction[]
  holdings            Holding[]
  budgetLinks         BudgetAccount[]
  importBatches       ImportBatch[]
  snapshots           AccountSnapshot[]
  invites             AccountInvite[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([type])
  @@index([isArchived])
}

model AccountMember {
  id           String              @id @default(cuid())
  accountId    String
  account      Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         AccountMemberRole   @default(viewer)
  relationType AccountRelationType @default(owner)
  invitedById  String?
  acceptedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([accountId, userId])
  @@index([userId])
  @@index([accountId, role])
}

model AccountInvite {
  id           String              @id @default(cuid())
  accountId    String
  account      Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  inviterId    String
  inviter      User                @relation("SentAccountInvites", fields: [inviterId], references: [id])
  acceptedById String?
  acceptedBy   User?               @relation("AcceptedAccountInvites", fields: [acceptedById], references: [id])
  email        String
  role         AccountMemberRole   @default(viewer)
  status       AccountInviteStatus @default(pending)
  tokenHash    String              @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([accountId, status])
  @@index([email, status])
  @@index([inviterId, createdAt])
}

enum AccountMemberRole {
  owner
  admin
  viewer
  editor
}

enum AccountRelationType {
  owner
  joint_owner
  manager
  beneficiary
  collaborator
}

enum AccountInviteStatus {
  pending
  accepted
  revoked
  expired
}

enum AccountType {
  bank
  cash
  savings
  broker
  exchange
  crypto_wallet
  credit_card
  loan
  mortgage
}

// ─── Transaction Domain ───────────────────────────────────────────────────────

model Transaction {
  id                String                     @id @default(cuid())
  date              DateTime
  bookingDate       DateTime?
  amount            Decimal                    @db.Decimal(18, 6)
  currency          String
  reportingAmount   Decimal?                   @db.Decimal(18, 6)
  reportingCurrency String?
  type              TransactionType
  classification    TransactionClassification?
  description       String?
  note              String?
  counterparty      String?
  externalId        String?
  isReviewed        Boolean                    @default(false)
  archivedAt        DateTime?
  deletedAt         DateTime?
  categoryId        String?
  category          Category?                  @relation(fields: [categoryId], references: [id])
  accountId         String
  account           Account                    @relation(fields: [accountId], references: [id])
  importBatchId     String?
  importBatch       ImportBatch?               @relation(fields: [importBatchId], references: [id])
  pair              TransactionPair?           @relation("PairFrom")
  pairedWith        TransactionPair?           @relation("PairTo")
  splits            TransactionSplit[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([accountId, date])
  @@index([accountId, externalId])
  @@index([categoryId, date])
  @@index([importBatchId])
}

enum TransactionType {
  income
  expense
  transfer
}

enum TransactionClassification {
  real_income
  real_expense
  internal_transfer
  investment_transfer
  loan_given
  loan_received
  loan_repayment
  refund
  cash_exchange
  credit_card_payment
  ignored
  needs_review
}

model TransactionPair {
  id                String      @id @default(cuid())
  fromTransactionId String      @unique
  toTransactionId   String      @unique
  fromTransaction   Transaction @relation("PairFrom", fields: [fromTransactionId], references: [id])
  toTransaction     Transaction @relation("PairTo", fields: [toTransactionId], references: [id])
  createdAt         DateTime    @default(now())
}

model TransactionSplit {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  amount        Decimal     @db.Decimal(18, 6)
  currency      String
  note          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([transactionId])
  @@index([categoryId])
}

// ─── Counterparty Domain ──────────────────────────────────────────────────────

model Counterparty {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  name          String
  type          CounterpartyType    @default(other)
  accountNumber String?
  iban          String?
  notes         String?
  aliases       CounterpartyAlias[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId])
  @@index([userId, name])
}

enum CounterpartyType {
  merchant
  family
  partner
  friend
  employer
  broker
  exchange
  bank
  service_provider
  other
}

model CounterpartyAlias {
  id             String         @id @default(cuid())
  counterpartyId String
  counterparty   Counterparty   @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
  alias          String
  matchType      AliasMatchType @default(contains)
  createdAt      DateTime       @default(now())

  @@index([counterpartyId])
}

enum AliasMatchType {
  exact
  contains
  starts_with
  ends_with
}

// ─── Category Domain ──────────────────────────────────────────────────────────

model Category {
  id           String               @id @default(cuid())
  name         String
  icon         String?
  color        String?
  type         CategoryType
  parentId     String?
  parent       Category?            @relation("Subcategories", fields: [parentId], references: [id])
  children     Category[]           @relation("Subcategories")
  isDefault    Boolean              @default(false)
  userId       String?
  transactions Transaction[]
  splits       TransactionSplit[]
  budgetItems  BudgetItemCategory[]
  rules        CategoryRule[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([userId])
  @@index([parentId])
  @@index([userId, type])
}

enum CategoryType {
  expense
  income
  both
}

model CategoryRule {
  id             String                     @id @default(cuid())
  value          String
  field          RuleField
  operator       RuleOperator               @default(contains)
  classification TransactionClassification?
  requiresReview Boolean                    @default(false)
  priority       Int                        @default(0)
  userId         String?
  categoryId     String
  category       Category                   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([field, operator])
}

enum RuleField {
  description
  counterparty
}

enum RuleOperator {
  contains
  equals
  starts_with
  ends_with
  greater_than
  less_than
}

// ─── Budget Domain ────────────────────────────────────────────────────────────

model Budget {
  id              String           @id @default(cuid())
  name            String
  periodStart     DateTime
  periodEnd       DateTime
  periodType      BudgetPeriodType @default(monthly)
  currency        String           @default("CZK")
  rolloverEnabled Boolean          @default(false)
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  accounts        BudgetAccount[]
  items           BudgetItem[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([userId, periodStart, periodEnd, name])
  @@index([userId, periodStart, periodEnd])
}

enum BudgetPeriodType {
  monthly
  weekly
  yearly
  custom
}

model BudgetItem {
  id             String               @id @default(cuid())
  name           String?
  amount         Decimal              @db.Decimal(18, 6)
  currency       String               @default("CZK")
  rolloverAmount Decimal?             @db.Decimal(18, 6)
  budgetId       String
  budget         Budget               @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  categories     BudgetItemCategory[]
  budgetAlerts   BudgetAlert[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([budgetId])
}

model BudgetItemCategory {
  id           String     @id @default(cuid())
  budgetItemId String
  budgetItem   BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([budgetItemId, categoryId])
  @@index([categoryId])
}

model BudgetAccount {
  id        String   @id @default(cuid())
  budgetId  String
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([budgetId, accountId])
  @@index([accountId])
}

model BudgetAlert {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  budgetItemId   String
  budgetItem     BudgetItem      @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  type           BudgetAlertType
  threshold      Decimal         @db.Decimal(5, 4)
  triggeredAt    DateTime        @default(now())
  acknowledgedAt DateTime?

  @@index([userId, triggeredAt])
  @@index([budgetItemId])
}

enum BudgetAlertType {
  approaching_limit
  exceeded
  reset
}

// ─── Investment Domain ────────────────────────────────────────────────────────

model Asset {
  id                   String                @id @default(cuid())
  symbol               String
  isin                 String?
  name                 String?
  assetType            AssetType
  currency             String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  aliases              AssetAlias[]
  listings             AssetListing[]
  priceSnapshots       PriceSnapshot[]
  holdings             Holding[]
  investmentMovements  InvestmentMovement[]
  accountSnapshotItems AccountSnapshotItem[]

  @@index([symbol])
  @@index([isin])
  @@index([assetType])
}

model AssetListing {
  id             String                @id @default(cuid())
  assetId        String
  asset          Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  symbol         String
  exchange       String?
  mic            String?
  currency       String
  country        String?
  provider       PriceSource?
  providerSymbol String?
  isPrimary      Boolean               @default(false)
  priceSnapshots PriceSnapshot[]
  holdings       Holding[]
  movements      InvestmentMovement[]
  snapshotItems  AccountSnapshotItem[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([assetId, symbol, exchange, currency])
  @@unique([symbol, exchange, currency])
  @@unique([provider, providerSymbol, currency])
  @@index([assetId])
  @@index([symbol])
  @@index([provider, providerSymbol])
}

model AssetAlias {
  id         String             @id @default(cuid())
  assetId    String
  asset      Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  provider   AssetAliasProvider
  externalId String
  createdAt  DateTime           @default(now())

  @@unique([provider, externalId])
  @@index([assetId, provider])
}

enum AssetAliasProvider {
  coingecko
  yahoo_finance
  stooq
  broker
  exchange
}

model PriceSnapshot {
  id        String       @id @default(cuid())
  assetId   String
  asset     Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  listingId String
  listing   AssetListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  price     Decimal      @db.Decimal(28, 10)
  currency  String
  source    PriceSource
  timestamp DateTime
  createdAt DateTime     @default(now())

  @@unique([listingId, timestamp, source])
  @@index([assetId, timestamp])
  @@index([listingId, timestamp])
  @@index([source, timestamp])
}

enum PriceSource {
  coingecko
  yahoo_finance
  stooq
  manual
  broker
  exchange
}

model InvestmentEvent {
  id                  String               @id @default(cuid())
  accountId           String
  account             Account              @relation(fields: [accountId], references: [id])
  type                InvestmentEventType
  date                DateTime
  source              ImportSource?
  externalId          String?
  orderId             String?
  description         String?
  realizedPnl         Decimal?             @db.Decimal(28, 10)
  realizedPnlCurrency String?
  importBatchId       String?
  importBatch         ImportBatch?         @relation(fields: [importBatchId], references: [id])
  movements           InvestmentMovement[]
  archivedAt          DateTime?
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([accountId, date])
  @@index([accountId, externalId])
  @@index([orderId])
  @@index([importBatchId])
}

model InvestmentMovement {
  id              String                 @id @default(cuid())
  eventId         String
  event           InvestmentEvent        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  accountId       String
  account         Account                @relation(fields: [accountId], references: [id])
  assetId         String?
  asset           Asset?                 @relation(fields: [assetId], references: [id])
  listingId       String?
  listing         AssetListing?          @relation(fields: [listingId], references: [id])
  kind            InvestmentMovementKind
  direction       MovementDirection
  quantity        Decimal                @db.Decimal(28, 10)
  currency        String
  pricePerUnit    Decimal?               @db.Decimal(28, 10)
  valueAmount     Decimal?               @db.Decimal(28, 10)
  valueCurrency   String?
  sourceSymbol    String?
  sourceAssetType AssetType?
  note            String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([eventId])
  @@index([accountId, createdAt])
  @@index([assetId])
  @@index([listingId])
  @@index([kind])
}

enum InvestmentEventType {
  trade
  cash_deposit
  cash_withdrawal
  dividend
  interest
  currency_conversion
  asset_transfer
  fee
  staking_reward
  airdrop
  adjustment
}

enum InvestmentMovementKind {
  asset
  cash
  fee
  tax
}

enum MovementDirection {
  in
  out
}

enum AssetType {
  stock
  etf
  crypto
  commodity
  cash
  bond
  other
}

model Holding {
  id            String       @id @default(cuid())
  symbol        String
  name          String?
  assetType     AssetType
  quantity      Decimal      @db.Decimal(28, 10)
  avgBuyPrice   Decimal      @db.Decimal(28, 10)
  currency      String
  currentPrice  Decimal?     @db.Decimal(28, 10)
  currentValue  Decimal?     @db.Decimal(28, 10)
  unrealizedPnl Decimal?     @db.Decimal(28, 10)
  realizedPnl   Decimal?     @db.Decimal(28, 10)
  assetId       String?
  asset         Asset?       @relation(fields: [assetId], references: [id])
  listingId     String
  listing       AssetListing @relation(fields: [listingId], references: [id])
  accountId     String
  account       Account      @relation(fields: [accountId], references: [id])
  calculatedAt  DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([accountId, listingId])
  @@index([accountId])
  @@index([assetId])
  @@index([listingId])
}

// ─── Market Data ──────────────────────────────────────────────────────────────

model ExchangeRate {
  id           String             @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal            @db.Decimal(18, 8)
  date         DateTime
  source       ExchangeRateSource
  createdAt    DateTime           @default(now())

  @@unique([fromCurrency, toCurrency, date, source])
  @@index([fromCurrency, toCurrency, date])
  @@index([source, date])
}

enum ExchangeRateSource {
  cnb
  ecb
  yahoo_finance
  manual
  broker
  exchange
}

// ─── Import Domain ────────────────────────────────────────────────────────────

model ImportBatch {
  id               String            @id @default(cuid())
  userId           String
  accountId        String
  source           ImportSource
  filename         String
  fileSize         Int?
  fileEncoding     String?
  checksum         String
  status           ImportStatus      @default(completed)
  rowsTotal        Int?
  rowsImported     Int?
  rowsSkipped      Int?
  createdAt        DateTime          @default(now())
  completedAt      DateTime?
  retainUntil      DateTime?
  rawDataPurgedAt  DateTime?
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account          Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  investmentEvents InvestmentEvent[]
  importRows       ImportRow[]
  importLogs       ImportLog[]

  @@unique([userId, accountId, checksum])
  @@index([userId, createdAt])
  @@index([accountId, createdAt])
  @@index([source, status])
}

enum ImportSource {
  raiffeisenbank
  trading212
  anycoin
  manual
}

enum ImportStatus {
  pending
  processing
  completed
  failed
  partially_completed
  cancelled
}

model ImportRow {
  id                       String          @id @default(cuid())
  importBatchId            String
  importBatch              ImportBatch     @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  rowNumber                Int
  rawData                  Json
  normalizedData           Json?
  validationErrors         Json?
  deduplicationKey         String?
  status                   ImportRowStatus @default(pending)
  errorMessage             String?
  createdTransactionId     String?
  createdInvestmentEventId String?
  createdAt                DateTime        @default(now())

  @@unique([importBatchId, rowNumber])
  @@index([importBatchId, status])
  @@index([deduplicationKey])
}

enum ImportRowStatus {
  pending
  imported
  skipped
  duplicate
  failed
  needs_review
}

model ImportLog {
  id            String         @id @default(cuid())
  importBatchId String
  importBatch   ImportBatch    @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  level         ImportLogLevel
  event         ImportLogEvent
  message       String?
  createdAt     DateTime       @default(now())

  @@index([importBatchId, createdAt])
  @@index([level, createdAt])
}

enum ImportLogLevel {
  info
  warning
  error
}

enum ImportLogEvent {
  started
  parse_error
  validation_failed
  dedup_skipped
  holdings_recalculated
  snapshots_recalculated
  snapshot_validation_failed
  completed
  failed
}

// ─── Snapshot Domain ──────────────────────────────────────────────────────────

model NetWorthSnapshot {
  id                         String              @id @default(cuid())
  userId                     String
  user                       User                @relation(fields: [userId], references: [id])
  timestamp                  DateTime
  granularity                SnapshotGranularity
  source                     SnapshotSource
  currency                   String              @default("CZK")
  cashValue                  Decimal             @db.Decimal(18, 6)
  portfolioValue             Decimal             @db.Decimal(18, 6)
  liabilitiesValue           Decimal             @db.Decimal(18, 6)
  totalNetWorth              Decimal             @db.Decimal(18, 6)
  cashValueByCurrency        Json?
  portfolioValueByCurrency   Json?
  liabilitiesValueByCurrency Json?
  totalNetWorthByCurrency    Json?
  exchangeRates              Json?
  isRecalculated             Boolean             @default(false)
  calculatedAt               DateTime            @default(now())
  calculationVersion         Int                 @default(1)
  createdAt                  DateTime            @default(now())

  @@unique([userId, timestamp, currency, granularity])
  @@index([userId, granularity, timestamp])
  @@index([source, timestamp])
}

enum SnapshotGranularity {
  minute
  hour
  day
  week
  month
}

enum SnapshotSource {
  import_event
  price_refresh
  holdings_recalculation
  scheduled
  manual_recalculation
}

model AccountSnapshot {
  id                            String                @id @default(cuid())
  accountId                     String
  account                       Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  timestamp                     DateTime
  granularity                   SnapshotGranularity
  source                        SnapshotSource
  currency                      String                @default("CZK")
  cashValue                     Decimal               @db.Decimal(18, 6)
  investmentValue               Decimal               @db.Decimal(18, 6)
  investmentCostBasis           Decimal               @default(0) @db.Decimal(18, 6)
  netDepositsValue              Decimal               @default(0) @db.Decimal(18, 6)
  realizedPnlValue              Decimal               @default(0) @db.Decimal(18, 6)
  unrealizedPnlValue            Decimal               @default(0) @db.Decimal(18, 6)
  feesValue                     Decimal               @default(0) @db.Decimal(18, 6)
  taxesValue                    Decimal               @default(0) @db.Decimal(18, 6)
  liabilitiesValue              Decimal               @db.Decimal(18, 6)
  totalValue                    Decimal               @db.Decimal(18, 6)
  cashValueByCurrency           Json?
  investmentValueByCurrency     Json?
  investmentCostBasisByCurrency Json?
  netDepositsByCurrency         Json?
  realizedPnlByCurrency         Json?
  unrealizedPnlByCurrency       Json?
  feesByCurrency                Json?
  taxesByCurrency               Json?
  exchangeRates                 Json?
  isRecalculated                Boolean               @default(false)
  calculatedAt                  DateTime              @default(now())
  calculationVersion            Int                   @default(1)
  items                         AccountSnapshotItem[]
  createdAt                     DateTime              @default(now())

  @@unique([accountId, timestamp, currency, granularity])
  @@index([accountId, granularity, timestamp])
  @@index([source, timestamp])
}

model AccountSnapshotItem {
  id                 String          @id @default(cuid())
  snapshotId         String
  snapshot           AccountSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  assetId            String?
  asset              Asset?          @relation(fields: [assetId], references: [id])
  listingId          String
  listing            AssetListing    @relation(fields: [listingId], references: [id])
  symbol             String
  quantity           Decimal         @db.Decimal(28, 10)
  pricePerUnit       Decimal         @db.Decimal(28, 10)
  priceCurrency      String?
  priceSource        PriceSource?
  priceTimestamp     DateTime?
  value              Decimal         @db.Decimal(18, 6)
  nativeValue        Decimal?        @db.Decimal(28, 10)
  valueCurrency      String?
  costBasis          Decimal?        @db.Decimal(28, 10)
  costCurrency       String?
  nativeCostBasis    Decimal?        @db.Decimal(28, 10)
  nativeCostCurrency String?
  allocationPct      Decimal         @db.Decimal(8, 4)
  createdAt          DateTime        @default(now())

  @@unique([snapshotId, listingId])
  @@index([assetId])
  @@index([listingId])
}
